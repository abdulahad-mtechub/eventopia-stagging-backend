              "path": ["api", "gurus", "applications", "me"]
            },
            "description": "Get current guru application status and details."
          },
          "response": []
        },
        {
          "name": "Update My Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"avatar_url\": \"https://cdn.example.com/new-avatar.jpg\",\n  \"agreed_to_terms\": true\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/gurus/applications/me",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "gurus", "applications", "me"]
            },
            "description": "Update guru application (avatar, agreements). Can only be updated while pending."
