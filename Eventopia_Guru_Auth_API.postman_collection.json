  "item": [
    {
      "name": "1. Invite Validation",
      "item": [
        {
          "name": "Validate Invite Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/gurus/invites/validate/{{INVITE_TOKEN}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "gurus", "invites", "validate", "{{INVITE_TOKEN}}"]
            },
            "description": "Validate a guru invite token before registration. Checks for expiry and usage status.\n\n**Error Scenarios:**\n- 404: Invite not found\n- 410: Invite expired\n- 409: Invite already used"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Authentication (Register/Login)",
      "item": [
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guru@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"invite_token\": \"abc123def456\",\n  \"device_token\": \"optional_device_id\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register new guru account with email, password, and invite token."
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guru@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password. Returns access token and refresh token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Email Verification",
      "item": [
        {
          "name": "Verify Email with OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guru@example.com\",\n  \"otp\": \"123456\",\n  \"purpose\": \"signup\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/verify-email",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "Verify email address with OTP code sent via email."
          },
          "response": []
        },
        {
          "name": "Verify Email with User ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user_12345\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/verify-email",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "verify-email"]
            },
            "description": "Alternative: Verify email using user ID instead of email address."
          },
          "response": []
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guru@example.com\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/otp/resend",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "otp", "resend"]
            },
            "description": "Resend OTP email if user didn't receive the first one."
          },
          "response": []
        }
      ]
    },
