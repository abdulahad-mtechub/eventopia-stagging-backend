        {
          "name": "Create Guru Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"network_manager_user_id\": \"nm_user_123\",\n  \"avatar_url\": \"https://cdn.example.com/avatar.jpg\",\n  \"agreed_to_terms\": true,\n  \"agreed_to_guru_agreement\": true\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/gurus/applications",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "gurus", "applications"]
            },
            "description": "Create guru application and accept terms of service + guru agreement.\n\n**Required fields:**\n- network_manager_user_id: ID of assigned network manager\n- agreed_to_terms: true\n- agreed_to_guru_agreement: true"
          },
          "response": []
        },
        {
          "name": "Get My Application",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
