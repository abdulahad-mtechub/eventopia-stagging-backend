{
  "info": {
    "_postman_id": "guru-auth-module-v1",
    "name": "Eventopia - Guru Auth Module API",
    "description": "Complete Guru registration, authentication, and onboarding API collection with all 13 screens, 5 client flows, and failure scenarios.",
