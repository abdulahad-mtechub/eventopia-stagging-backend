{
  "info": {
    "_postman_id": "escrow-system-tests-2026",
    "name": "Escrow System API Tests",
    "description": "Testing Escrow APIs for Kings Account and Promoter roles",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "CONTRACT 15 - Coverage Ratio",
      "item": [
        {
          "name": "Get Coverage (Kings Account)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{kings_account_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/escrow/coverage/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "escrow", "coverage", "1"]
            },
            "description": "Get coverage ratio for territory 1. Should return GREEN/AMBER/RED status and breakdown."
          },
          "response": []
        },
        {
          "name": "Get Coverage (Invalid Territory)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{kings_account_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/escrow/coverage/99999",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "escrow", "coverage", "99999"]
            },
            "description": "Try to get coverage for non-existent territory. Should return 404 TERRITORY_NOT_FOUND."
          },
          "response": []
        }
      ]
    },
    {
      "name": "CONTRACT 16 - Promoter Escrow",
      "item": [
        {
          "name": "Get Own Escrow (Promoter)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{promoter_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/promoter/finance/escrow",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "promoter", "finance", "escrow"]
            },
            "description": "Promoter views their own escrow holdings. Shows events and totals for their held and payout-eligible funds."
          },
          "response": []
        },
        {
          "name": "Get Other Promoter (Kings Account)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{kings_account_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/promoter/finance/escrow?promoter_id=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "promoter", "finance", "escrow"],
              "query": [
                {
                  "key": "promoter_id",
                  "value": "5"
                }
              ]
            },
            "description": "Kings Account can view any promoter's escrow via query param promoter_id. Change promoter_id as needed."
          },
          "response": []
        }
      ]
    },
    {
      "name": "CONTRACT 17 - Interest History",
      "item": [
        {
          "name": "Get Interest History (Kings Account)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{kings_account_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/escrow/interest/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "escrow", "interest", "1"]
            },
            "description": "Get all interest history for territory 1. Returns summary of total interest earned and detailed entries."
          },
          "response": []
        },
        {
          "name": "Get Interest with Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{kings_account_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/escrow/interest/1?from=2026-02-01&to=2026-02-28",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "escrow", "interest", "1"],
              "query": [
                {
                  "key": "from",
                  "value": "2026-02-01"
                },
                {
                  "key": "to",
                  "value": "2026-02-28"
                }
              ]
            },
            "description": "Get interest history filtered by date range. Use format YYYY-MM-DD for from and to dates."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "kings_account_token",
      "value": "your_kings_account_jwt_token_here",
      "type": "string"
    },
    {
      "key": "promoter_token",
      "value": "your_promoter_jwt_token_here",
      "type": "string"
    }
  ]
}
